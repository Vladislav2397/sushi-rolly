{
    "name": "sushi-rolly",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vike dev",
        "build": "vike build",
        "preview": "vike preview",
        "format": "prettier --write .",
        "typecheck": "vue-tsc --noEmit",
        "db:up": "docker compose up -d",
        "db:down": "docker compose down",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:seed": "tsx server/database/seed.ts",
        "db:seed-admin": "tsx server/database/seed-admin.ts",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@fontsource-variable/manrope": "^5.3.0",
        "@fontsource-variable/syne": "^5.3.0",
        "@iconify/vue": "^5.0.1",
        "@vikejs/hono": "^0.2.1",
        "bcryptjs": "^3.0.3",
        "drizzle-orm": "^0.45.2",
        "hono": "^4.12.31",
        "ofetch": "^1.5.1",
        "pinia": "^4.0.2",
        "postgres": "^3.4.9",
        "reka-ui": "^2.10.1",
        "tailwindcss": "^4.3.3",
        "vike": "^0.4.260",
        "vike-vue": "^0.9.13",
        "vue": "^3.5.40",
        "vue-router": "^5.2.0"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.2.1",
        "@iconify-json/lucide": "^1.2.118",
        "@storybook/addon-a11y": "^10.5.3",
        "@storybook/addon-docs": "^10.5.3",
        "@storybook/addon-vitest": "^10.5.3",
        "@storybook/vue3-vite": "^10.5.3",
        "@tailwindcss/vite": "^4.3.3",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^26.1.1",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vitest/browser-playwright": "^4.1.10",
        "@vitest/coverage-v8": "^4.1.10",
        "@vue/test-utils": "^2.4.11",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "happy-dom": "^20.11.0",
        "playwright": "^1.61.1",
        "prettier": "^3.9.5",
        "storybook": "^10.5.3",
        "tsx": "^4.23.1",
        "typescript": "^6.0.3",
        "vite": "^8.1.5",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
