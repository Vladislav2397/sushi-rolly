{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["vite/client"],
        "paths": {
            "@shared": ["./app/shared"],
            "@shared/*": ["./app/shared/*"],
            "@entities": ["./app/entities"],
            "@entities/*": ["./app/entities/*"],
            "@features": ["./app/features"],
            "@features/*": ["./app/features/*"],
            "@widgets": ["./app/widgets"],
            "@widgets/*": ["./app/widgets/*"],
            "@pages": ["./app/pages"],
            "@pages/*": ["./app/pages/*"]
        }
    },
    "include": [
        "pages/**/*",
        "app/**/*",
        "server/**/*",
        "vite.config.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
