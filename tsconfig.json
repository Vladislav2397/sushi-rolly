{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["vite/client"],
        "paths": {
            "@shared": ["./src/shared"],
            "@shared/*": ["./src/shared/*"],
            "@entities": ["./src/entities"],
            "@entities/*": ["./src/entities/*"],
            "@features": ["./src/features"],
            "@features/*": ["./src/features/*"],
            "@widgets": ["./src/widgets"],
            "@widgets/*": ["./src/widgets/*"],
            "@pages": ["./src/pages"],
            "@pages/*": ["./src/pages/*"]
        }
    },
    "include": [
        "pages/**/*",
        "src/**/*",
        "server/**/*",
        ".storybook/**/*",
        "vite.config.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
